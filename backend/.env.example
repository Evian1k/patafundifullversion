NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fixit_connect
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=7d

# Admin bootstrap (used by: npm --prefix backend run setup-admin)
ADMIN_EMAIL=emmanuelevian@gmail.com
ADMIN_PASSWORD=change-me
ADMIN_FULL_NAME=Admin

# Backend URL (for file serving)
BACKEND_URL=http://localhost:5000

# Email (SMTP) - required for OTP in production
# Gmail example (use an App Password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx  # App Password shown with spaces; backend will strip spaces automatically
# FROM_EMAIL=your@gmail.com
# REQUIRE_SMTP=true
# SMTP_DEBUG=false

# OCR (ID verification)
# Dev-only escape hatch: set true to allow fundi registration even if OCR mismatches.
# Never enable in production.
OCR_BYPASS=false

# Dev-only: if true, OCR mismatches become a warning and the registration is still submitted to admin for review.
# In production, OCR mismatch remains a hard failure.
OCR_SOFT_FAIL=false

# Dev/testing only: echo OTP code in API JSON responses (never enable in production).
DEV_ECHO_OTP=false

# Optional business rule: require active subscription for fundis to go online / appear in search.
REQUIRE_FUNDI_SUBSCRIPTION=false

# GPS accuracy gate (meters). Higher values are more lenient (helpful indoors / weak GPS).
FUNDI_ONLINE_MAX_ACCURACY_METERS=300

# Dev convenience: allow fundis to go online even with very poor or missing GPS accuracy.
# Useful on desktop browsers that report huge accuracy values. Never enable in production.
ALLOW_LOW_ACCURACY_ONLINE=true

# Dev convenience: allow activating subscription without M-Pesa configured.
# In production you must configure MPESA_* env vars and disable this.
ALLOW_DEV_SUBSCRIPTION_BYPASS=true

# Job matching + pricing
# Radii the system will try (in km). If no fundi is found in the first radius,
# it automatically expands to the next radius until exhausted.
JOB_SEARCH_RADII_KM=3,6,10,15
JOB_REQUEST_BATCH_SIZE=5
JOB_REQUEST_TIMEOUT_SEC=20

# Fundi arrival verification (meters). If fundi is farther than this from the customer pin,
# ARRIVED is rejected (anti-cheat + correctness).
ARRIVAL_MAX_DISTANCE_METERS=150

# Simple distance-based pricing (fallbacks if service_categories has no pricing configured)
DEFAULT_BASE_PRICE=1000
DEFAULT_PER_KM_RATE=150
PRICE_INCLUDED_KM=2
