NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:8080

# PostgreSQL (local dev)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fixit_connect
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=change-me
JWT_EXPIRY=7d

# Optional: auto-create schema on boot (useful for hosts without shell/one-off jobs)
DB_AUTO_SETUP=false

# OCR can be slow; async mode improves UX in dev (admin still reviews)
OCR_ASYNC=true

# Optional: only for local/dev bootstrap flows (do not enable in production)
ADMIN_AUTO_BOOTSTRAP=false
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FULL_NAME=

# Public base URL for file links (set this on your host in production)
BACKEND_URL=http://localhost:5000

# Email (SMTP) for OTP delivery (set real creds on your host)
# NOTE: Some hosts (including Render Free) block outbound SMTP (ports 25/465/587). In that case,
# use an HTTPS email provider and set EMAIL_TRANSPORT=resend or EMAIL_TRANSPORT=sendgrid.
EMAIL_TRANSPORT=auto
RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
SMTP_DEBUG=false
# Timeouts (ms) - prevents long hangs on blocked SMTP networks
SMTP_CONNECTION_TIMEOUT=8000
SMTP_GREETING_TIMEOUT=8000
SMTP_SOCKET_TIMEOUT=15000

# Branding / Support (optional; used for legal pages + footer content)
COMPANY_NAME=PataFundi
SUPPORT_EMAIL=patafundi6@gmail.com

# Seed default content (policies/blog/faqs/careers) on boot (idempotent)
SEED_DEFAULT_CONTENT=true
# Optional: overwrite policy sections with newest defaults
SEED_DEFAULT_CONTENT_FORCE=false
