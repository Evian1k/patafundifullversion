NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:8080

# PostgreSQL (local dev)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fixit_connect
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=change-me
JWT_EXPIRY=7d

# Optional: auto-create schema on boot (useful for hosts without shell/one-off jobs)
DB_AUTO_SETUP=false

# Optional: only for local/dev bootstrap flows (do not enable in production)
ADMIN_AUTO_BOOTSTRAP=false
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FULL_NAME=

# Public base URL for file links (set this on your host in production)
BACKEND_URL=http://localhost:5000

# Email (SMTP) for OTP delivery (set real creds on your host)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
SMTP_DEBUG=false
